<launch>
<!-- Launch file for Livox MID360 LiDAR -->

	<arg name="rviz" default="false" />

	<rosparam command="load" file="$(find fast_lio)/config/mid360.yaml" />
	<rosparam command="load" file="$(find fast_lio)/config/anomaly_detection.yaml" />
	<!-- IMU initial position parameters -->
	<param name="init_imu_pos_x" type="double" value="0"/>
	<param name="init_imu_pos_y" type="double" value="0"/>
	<param name="init_imu_pos_z" type="double" value="0"/>
	
	<param name="feature_extract_enable" type="bool" value="0"/>
	<!-- 10 -->
	<!-- <param name="point_filter_num" type="int" value="3"/> -->
	<param name="point_filter_num" type="int" value="6"/>
	<!-- 1,2 -->
	<!-- <param name="max_icp_times" type="int" value="2" />
	<param name="max_iteration" type="int" value="4" /> -->
	<param name="max_icp_times" type="int" value="2" />
	<param name="max_iteration" type="int" value="4" />
	<!-- 0.5 -->
	<param name="filter_size_surf" type="double" value="0.2" />

	<param name="filter_size_map" type="double" value="0.2" />
	<param name="cube_side_length" type="double" value="1000" />
	<param name="runtime_pos_log_enable" type="bool" value="0" />

	<!-- wxx 先验局部点云发布: 以当前位置为心截球(半径r)采集先验地图点, 降采样后发布
	     /prior_local_cloud(仅额外点云) 与 /cloud_registered_with_prior(当前帧+额外点云) -->
	<param name="wxx/prior_local_enable"        type="bool"   value="true" />
	<param name="wxx/prior_local_radius"        type="double" value="5.0" />
	<param name="wxx/prior_local_motion_check"  type="bool"   value="false" />
	<param name="wxx/prior_local_motion_thresh" type="double" value="0.5" />
    <node pkg="fast_lio" type="fastlio_mapping" name="laserMapping" output="screen" />
    <node pkg="fast_lio" type="cpu_monitor" name="cpu_monitor" output="screen" /> 

	<group if="$(arg rviz)">
	<node launch-prefix="nice" pkg="rviz" type="rviz" name="rviz" args="-d $(find fast_lio)/rviz_cfg/loam_livox.rviz" />
	</group>

</launch>
