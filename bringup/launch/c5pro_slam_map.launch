<launch>
  <arg name="bd_list" default="000000000000000" />
  <arg name="imu_src" default="mavros" doc="livox or mavros" />
  <include file="$(find bringup)/launch/c5pro_livox.launch">
    <arg name="xfer_format" value="1" />
    <arg name="bd_list" value="$(arg bd_list)" />
  </include>
  <include file="$(find bringup)/launch/c5pro_mapping.launch">
    <arg name="imu_src" value="$(arg imu_src)" />
  </include>
  <include file="$(find incremental_map_publisher)/launch/rolling_map_publisher.launch" />
</launch>
