<launch>
  <arg name="bd_list" default="000000000000000" />
  <include file="$(find bringup)/launch/msg_MID360.launch">
    <arg name="bd_list" value="$(arg bd_list)" />
  </include>
  <rosparam command="load" file="$(find bringup)/config/smoke_fov_test.yaml" />
  <rosparam command="load" file="$(find bringup)/config/anomaly_detection.yaml" />
  <node pkg="fast_lio" type="fastlio_mapping" name="laserMapping" output="screen" />
</launch>
